generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model Project {
  id            String   @id @default(cuid())
  name          String
  country       String
  city          String?
  description   String
  images        String[]
  videoUrl      String?
  googleMapsUrl String?
  price         Float
  currency      String   @default("EUR")
  agentName     String?
  agentEmail    String?
  agentPhone    String?
  isActive      Boolean  @default(true)

  // matching criteria (checkboxes in admin)
  forLiving     Boolean @default(false)
  forVacation   Boolean @default(false)
  forInvestment Boolean @default(false)

  offPlan       Boolean @default(false)
  ready         Boolean @default(false)

  commercial    Boolean @default(false)
  touristic     Boolean @default(false)
  residential   Boolean @default(false)
  agricultural  Boolean @default(false)
  buildingPlot  Boolean @default(false)

  monthlyRental Boolean @default(false)
  shortSale     Boolean @default(false)
  longSale      Boolean @default(false)

  budgets       String[]

  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  results AssessmentResult[]
}

model Assessment {
  id           String   @id @default(cuid())
  purpose      String
  status       String
  propertyType String
  priority     String
  saleTimeline String
  budget       String
  createdAt    DateTime @default(now())

  results AssessmentResult[]
  lead    Lead?
}

model AssessmentResult {
  id           String     @id @default(cuid())
  assessmentId String
  projectId    String
  score        Int
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
  project      Project    @relation(fields: [projectId], references: [id])
}

model Lead {
  id           String     @id @default(cuid())
  assessmentId String     @unique
  name         String
  email        String
  phone        String?
  projectId    String?
  createdAt    DateTime   @default(now())
  assessment   Assessment @relation(fields: [assessmentId], references: [id])
}
